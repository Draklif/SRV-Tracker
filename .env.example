# Entorno de ejecución
NODE_ENV=development
PORT=3000

# Base de datos (archivo SQLite). Relativa a la raíz del proyecto.
DATABASE_PATH=data/tracker.db

# Secreto para firmar cookies de sesión y tokens CSRF.
# Genera uno propio en producción: `openssl rand -hex 32`
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
CSRF_SECRET=cambia-esto-tambien-por-otro-secreto

# Zona horaria por defecto para nuevos usuarios (IANA).
DEFAULT_TIMEZONE=America/Mexico_City
