# Entorno de ejecución
NODE_ENV=development
PORT=3000

# Base de datos (archivo SQLite). Relativa a la raíz del proyecto.
DATABASE_PATH=data/tracker.db

# Secreto para firmar cookies de sesión y tokens CSRF.
# Genera uno propio en producción: `openssl rand -hex 32`
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
CSRF_SECRET=cambia-esto-tambien-por-otro-secreto

# Zona horaria por defecto para nuevos usuarios (IANA).
DEFAULT_TIMEZONE=America/Mexico_City

# URL pública canónica (con https) para las previews sociales (Open Graph).
# Recomendado en producción. Si se deja vacía, se deriva del host de la petición.
PUBLIC_URL=

# Descripción del sitio para el <head> y las previews sociales.
SITE_DESCRIPTION=Rastreador de hábitos gamificado y acogedor para compartir con tus amigos.

# Ritmo de la economía de monedas. Multiplica lo que se GANA (nunca los precios
# de la tienda, que viven en el catálogo). 1 = ritmo normal (≈38 monedas al día
# con 4 hábitos); 2 = el doble; 0 congela la economía sin cerrar la tienda.
# Cambiarlo no revalúa las monedas ya ganadas: solo afecta a lo que se acuñe desde
# el reinicio.
COIN_RATE=1

# Notificaciones push (Web Push / VAPID). Genera las claves EN EL SERVIDOR con:
#   npx web-push generate-vapid-keys
# Sin estas claves, las notificaciones quedan deshabilitadas (la app funciona igual).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
# Hora local (0-23) del aviso "tu racha peligra". Por defecto 21 (9pm).
NOTIFY_STREAK_GUARD_HOUR=21
