<% const pageScripts = ['/js/profile.js']; %>
<%- include('../partials/head', { title, styles: ['/css/pages/profile.css'] }) %>

<%- include('../partials/app-nav') %>

<main class="container profile-page">
  <%- include('../partials/flash') %>

  <header class="profile-header card">
    <!-- Tocar el avatar abre el selector; elegir imagen la sube al instante. -->
    <form method="post" action="/profile/avatar" enctype="multipart/form-data" class="avatar-upload-form">
      <%- include('../partials/csrf-field') %>
      <label class="avatar-upload" title="Cambiar avatar">
        <%- include('../partials/avatar', { avatarUser: user, size: 'lg' }) %>
        <span class="avatar-upload-badge"><%- include('../partials/icon', { name: 'camera', size: 15 }) %></span>
        <input type="file" id="avatar-input" name="avatar"
          accept="image/png,image/jpeg,image/webp,image/gif" hidden />
      </label>
    </form>
    <div class="profile-id">
      <h1><%= user.display_name %></h1>
      <p class="text-muted">@<%= user.username %></p>
      <% if (user.bio) { %><p class="profile-bio"><%= user.bio %></p><% } %>
    </div>
    <div class="profile-level">
      <span class="chip">Nivel <%= level.level %></span>
      <span class="profile-xp text-muted"><%= level.xp %> XP</span>
    </div>
  </header>

  <!-- Recursos generados (se acumulan en la pool para la futura aldea) -->
  <section class="card resources-section">
    <h2>Recursos</h2>
    <p class="text-muted res-summary">Lo que tus hábitos han aportado a la aldea</p>
    <div class="res-grid">
      <% Object.entries(resourceTypeMeta).forEach(([key, m]) => { %>
      <div class="res-tile" title="<%= m.desc %>">
        <span class="res-icon"><%- include('../partials/icon', { name: key, size: 30 }) %></span>
        <span class="res-total"><%= resources[key] || 0 %></span>
        <span class="res-name"><%= m.label %></span>
      </div>
      <% }) %>
    </div>
  </section>

  <!-- Logros e insignias (solo los conseguidos: la vitrina crece contigo) -->
  <section class="card achievements-section">
    <h2>Logros</h2>
    <% const unlocked = achievements.filter((a) => a.unlocked_at); %>
    <p class="text-muted ach-summary"><%= unlocked.length %> de <%= achievements.length %> descubiertos</p>
    <% if (unlocked.length === 0) { %>
    <p class="text-muted ach-empty">Tu vitrina está esperando. El primer logro llega con tu primer registro 🌱</p>
    <% } else { %>
    <div class="ach-grid">
      <% unlocked.forEach((a) => { %>
      <div class="ach-badge is-unlocked tier-<%= a.tier %>" title="<%= a.description %>">
        <span class="ach-icon"><%= a.icon %></span>
        <span class="ach-name"><%= a.name %></span>
        <span class="ach-desc"><%= a.description %></span>
        <span class="ach-check">✓</span>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>

  <div class="profile-grid">
    <!-- Datos del perfil -->
    <section class="card">
      <h2>Tu perfil</h2>
      <form method="post" action="/profile" class="form" novalidate>
        <%- include('../partials/csrf-field') %>

        <%- include('../partials/field', { field: {
          name: 'displayName', label: 'Nombre para mostrar', value: values.displayName,
          error: profileErrors.displayName, required: true
        } }) %>

        <div class="field <%= profileErrors.bio ? 'field-invalid' : '' %>">
          <label for="bio">Bio</label>
          <textarea id="bio" name="bio" rows="3" maxlength="160"
            placeholder="Una frase sobre ti…"><%= values.bio %></textarea>
          <% if (profileErrors.bio) { %>
          <small class="field-error"><%= profileErrors.bio %></small>
          <% } %>
        </div>

        <div class="field">
          <label for="timezone">Zona horaria</label>
          <select id="timezone" name="timezone">
            <% timezones.forEach((tz) => { %>
            <option value="<%= tz %>" <%= values.timezone === tz ? 'selected' : '' %>><%= tz %></option>
            <% }) %>
          </select>
          <%
            // El "día" de la app es la fecha local; el reinicio es a medianoche.
            let nowLocal = '';
            try {
              nowLocal = new Intl.DateTimeFormat('es-MX', {
                timeZone: values.timezone, hour: '2-digit', minute: '2-digit', hour12: false,
              }).format(new Date());
            } catch (_) { nowLocal = ''; }
          %>
          <small class="field-hint">
            Tu día se reinicia a las 00:00<% if (nowLocal) { %> · ahora son las <%= nowLocal %> en tu zona<% } %>.
          </small>
        </div>

        <div class="field">
          <label for="theme">Tema</label>
          <select id="theme" name="theme">
            <% themes.forEach((t) => { %>
            <option value="<%= t %>" <%= values.theme === t ? 'selected' : '' %>>
              <%= t === 'dark' ? '🌙 Oscuro' : '☀️ Claro' %>
            </option>
            <% }) %>
          </select>
        </div>

        <button class="btn btn-primary" type="submit">Guardar cambios</button>
      </form>
    </section>

    <!-- Contraseña -->
    <section class="card">
      <h2>Cambiar contraseña</h2>
      <form method="post" action="/profile/password" class="form" novalidate>
        <%- include('../partials/csrf-field') %>

        <%- include('../partials/field', { field: {
          name: 'currentPassword', label: 'Contraseña actual', type: 'password',
          error: passwordErrors.currentPassword, required: true, autocomplete: 'current-password'
        } }) %>

        <%- include('../partials/field', { field: {
          name: 'newPassword', label: 'Nueva contraseña', type: 'password',
          error: passwordErrors.newPassword, required: true, autocomplete: 'new-password',
          hint: 'Mínimo 8 caracteres'
        } }) %>

        <%- include('../partials/field', { field: {
          name: 'newPasswordConfirm', label: 'Repite la nueva', type: 'password',
          error: passwordErrors.newPasswordConfirm, required: true, autocomplete: 'new-password'
        } }) %>

        <button class="btn btn-primary" type="submit">Actualizar contraseña</button>
      </form>
    </section>

    <!-- Invitaciones: cada persona puede invitar a alguien más -->
    <section class="card invite-section">
      <h2>Invitar a alguien</h2>
      <p class="text-muted invite-intro">
        Genera un código y compártelo. Caduca en <%= inviteTtlMinutes >= 60 ? '1 hora' : `${inviteTtlMinutes} min` %>,
        al usarse o al generar uno nuevo.
      </p>

      <% if (activeInvite) { %>
      <div class="invite-active" data-expires-at="<%= activeInvite.expires_at %>">
        <code class="invite-code"><%= activeInvite.code %></code>
        <button type="button" class="btn btn-ghost btn-sm invite-copy"
          data-code="<%= activeInvite.code %>"
          data-url="<%= baseUrl %>/register?code=<%= activeInvite.code %>"
          data-app="<%= appName %>">
          Copiar invitación
        </button>
        <p class="invite-expiry text-muted" aria-live="polite"></p>
      </div>
      <% } else { %>
      <p class="text-muted invite-empty">No tienes ningún código activo.</p>
      <% } %>

      <form method="post" action="/profile/invite" class="form invite-form">
        <%- include('../partials/csrf-field') %>
        <button class="btn btn-primary" type="submit">
          <%= activeInvite ? 'Generar otro código' : 'Generar código' %>
        </button>
      </form>
    </section>
  </div>
</main>

<%- include('../partials/foot', { scripts: pageScripts }) %>
