<% const pageScripts = ['/js/api.js', '/js/toast.js', '/js/tracker.js']; %>
<%- include('../partials/head', { title, styles: ['/css/pages/home.css'] }) %>

<%- include('../partials/app-nav') %>

<main class="container home-page" data-today="<%= today %>">
  <%- include('../partials/flash') %>

  <section class="greeting card">
    <div class="greeting-text">
      <h1>Hola, <%= user.display_name %> 🌱</h1>
      <p class="text-muted">Cada pequeño paso cuenta. Nos alegra tenerte por aquí.</p>
    </div>
    <div class="level-badge">
      <span class="level-num" data-level-num>Nivel <%= level.level %></span>
      <div class="level-bar">
        <span class="level-fill" data-level-fill style="width: <%= level.percent %>%"></span>
      </div>
      <span class="level-caption text-muted" data-level-caption>
        <%= level.xp %> XP · <%= level.toNext %> para el nivel <%= level.level + 1 %>
      </span>
    </div>
  </section>

  <% if (habits.length) { %>
  <%- include('../partials/day-progress', { dayProgress }) %>

  <section class="tracker-section">
    <h2 class="section-title">Hoy</h2>
    <div class="tracker-list" id="tracker-list">
      <% habits.forEach((habit) => { %>
      <%- include('../partials/tracker-card', { habit }) %>
      <% }) %>
    </div>
  </section>
  <% } else { %>
  <section class="soon card">
    <span class="soon-emoji">🎯</span>
    <h2>Empieza por tus hábitos</h2>
    <p class="text-muted">
      Crea los hábitos que quieres cultivar y aparecerán aquí para registrarlos cada día.
    </p>
    <a class="btn btn-primary" href="/habits">Crear mi primer hábito</a>
  </section>
  <% } %>

  <% if (activity.length) { %>
  <section class="friends-activity">
    <div class="fa-head">
      <h2 class="section-title">Amigos</h2>
      <a class="link" href="/social">Ver todo →</a>
    </div>
    <div class="fa-list">
      <% activity.forEach((event) => { %>
      <%- include('../partials/feed-item', { event, reactionEmojis: [], timeAgo }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="quick-links">
    <a class="quick-link card" href="/habits">
      <span class="ql-icon"><%- include('../partials/icon', { name: 'target', size: 24 }) %></span>
      <span class="ql-label">Hábitos</span>
    </a>
    <a class="quick-link card" href="/social">
      <span class="ql-icon"><%- include('../partials/icon', { name: 'users', size: 24 }) %></span>
      <span class="ql-label">Amigos</span>
    </a>
    <a class="quick-link card" href="/profile">
      <span class="ql-icon"><%- include('../partials/icon', { name: 'user', size: 24 }) %></span>
      <span class="ql-label">Tu perfil</span>
    </a>
  </section>
</main>

<%- include('../partials/foot', { scripts: pageScripts }) %>
