<%- include('../partials/head', { title, styles: ['/css/pages/changelog.css'] }) %>

<%- include('../partials/app-nav') %>

<main class="container changelog-page">
  <%- include('../partials/flash') %>

  <header class="changelog-header card">
    <h1>
      <span class="changelog-title-icon"><%- include('../partials/icon', { name: 'sparkles', size: 24 }) %></span>
      Novedades
    </h1>
    <p class="text-muted">Lo que ha ido cambiando en la app. Toca una versión para desplegarla.</p>
  </header>

  <%
    // Las etiquetas de cada tipo de cambio (el color lo pone changelog.css).
    const TYPE_LABELS = { new: 'Nuevo', change: 'Cambia', fix: 'Arreglado', remove: 'Eliminado' };
  %>
  <ol class="changelog-list">
    <% entries.forEach((entry, i) => { %>
    <%
      // Abierta de entrada la más reciente; el resto colapsadas para que la
      // página no crezca sin control a medida que se acumulen versiones.
      const open = i === 0;
    %>
    <li class="card changelog-entry <%= open ? 'is-open' : '' %> <%= entry.isNew ? 'is-new' : '' %>">
      <div class="changelog-entry-head">
        <div class="changelog-entry-id">
          <span class="chip changelog-version"><%= entry.version %></span>
          <% if (entry.isNew) { %><span class="changelog-new-tag">Nuevo para ti</span><% } %>
        </div>
        <h2 class="changelog-entry-title"><%= entry.title %></h2>
        <time class="changelog-date text-muted" datetime="<%= entry.date %>">
          <%= new Intl.DateTimeFormat('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(entry.date + 'T12:00:00')) %>
        </time>
        <span class="changelog-chevron"><%- include('../partials/icon', { name: 'down', size: 18 }) %></span>
      </div>

      <ul class="changelog-items">
        <% entry.items.forEach((item) => { %>
        <li class="changelog-item">
          <span class="changelog-tag tag-<%= item.type %>"><%= TYPE_LABELS[item.type] || item.type %></span>
          <span class="changelog-text"><%= item.text %></span>
        </li>
        <% }) %>
      </ul>
    </li>
    <% }) %>
  </ol>
</main>

<%- include('../partials/foot', { scripts: ['/js/changelog.js'] }) %>
