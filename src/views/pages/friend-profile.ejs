<% const pageScripts = ['/js/api.js', '/js/friends.js', '/js/achievements.js']; %>
<%- include('../partials/head', { title, styles: ['/css/pages/profile.css', '/css/pages/friend.css'] }) %>

<%- include('../partials/app-nav') %>

<main class="container profile-page" id="friends-hub">
  <a class="back-link" href="/social">← Volver al feed</a>

  <header class="profile-header friend-header card">
    <%- include('../partials/avatar', { avatarUser: friend, size: 'lg' }) %>
    <div class="profile-id">
      <h1><%= friend.display_name %></h1>
      <p class="text-muted">@<%= friend.username %></p>
      <% if (friend.bio) { %><p class="profile-bio"><%= friend.bio %></p><% } %>
    </div>
    <!-- Acción de amistad y nivel juntos: la bio se queda con todo el ancho. -->
    <div class="friend-meta">
      <div class="user-row profile-friend-action" data-user-id="<%= friend.id %>" data-username="<%= friend.username %>" data-row-mode="directory">
        <%- include('../partials/user-row-action', { rel: friendStatus.rel, friendshipId: friendStatus.friendshipId, rowUser: friend }) %>
      </div>
      <div class="profile-level">
        <span class="chip">Nivel <%= level.level %></span>
        <span class="profile-xp text-muted"><%= level.xp %> XP</span>
      </div>
    </div>
  </header>

  <!-- El radar es público entre amigos: se ve su forma, no sus hábitos. -->
  <section class="card resources-section">
    <h2>Dimensiones</h2>
    <p class="text-muted res-summary">Su ritmo de siempre, y cómo va estos 7 días</p>
    <%- include('../partials/resource-radar', { radar }) %>
  </section>

  <% if (topStreaks.length) { %>
  <section class="card">
    <h2 class="friend-section-title">Rachas en curso</h2>
    <div class="friend-streaks">
      <% topStreaks.forEach((s) => { %>
      <div class="friend-streak" style="--habit-color: <%= habitColors[s.color] || habitColors.blue %>">
        <span class="fs-icon"><%= s.icon %></span>
        <div class="fs-body">
          <span class="fs-name"><%= s.name %></span>
          <span class="fs-days">🔥 <%= s.current_streak %> días</span>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="card achievements-section">
    <h2>Logros</h2>
    <p class="text-muted ach-summary"><%= unlocked.length %> de <%= totalAchievements %> descubiertos</p>
    <% if (unlocked.length === 0) { %>
    <p class="text-muted">Todavía está calentando motores 🌱</p>
    <% } else { %>
    <div class="ach-grid">
      <% unlocked.forEach((a) => { %>
      <div class="ach-badge is-unlocked tier-<%= a.tier %>" title="<%= a.description %>">
        <span class="ach-icon"><%= a.icon %></span>
        <span class="ach-name"><%= a.name %></span>
        <span class="ach-desc"><%= a.description %></span>
        <span class="ach-check">✓</span>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>
</main>

<%- include('../partials/foot', { scripts: pageScripts }) %>
