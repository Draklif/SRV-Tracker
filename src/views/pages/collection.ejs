<%- include('../partials/head', { title, styles: ['/css/pages/profile.css', '/css/pages/collection.css'] }) %>

<%- include('../partials/app-nav') %>

<main class="container collection-page">
  <%- include('../partials/flash') %>

  <%
    const cos = cosmeticsFor(user);
    const title0 = cos.title;
  %>

  <header class="col-intro">
    <h1>Colección</h1>
  </header>

  <!-- Vista previa: reusa la MISMA estructura que la cabecera del perfil
       (.profile-header) para que se vea idéntica a como la ven los demás,
       con su bio y su espaciado. Se actualiza al vuelo al equipar. -->
  <section class="col-preview profile-header card <%= cosmeticCardClasses(cos) %>"
    id="cos-preview" aria-label="Vista previa de tu tarjeta">
    <span class="avatar-wrap avatar-wrap-lg <%= cosmeticFrameClasses(cos.avatar_frame) %>">
      <% if (user.avatar_path) { %>
      <img class="avatar avatar-lg" src="<%= user.avatar_path %>" alt="" />
      <% } else { %>
      <span class="avatar avatar-lg avatar-initials"><%= (user.display_name || user.username).trim().charAt(0).toUpperCase() %></span>
      <% } %>
      <span class="cos-frame <%= cos.avatar_frame ? cos.avatar_frame.css : '' %>"
        data-preview="avatar_frame" aria-hidden="true" <%= cos.avatar_frame ? '' : 'hidden' %>></span>
      <span class="cos-deco <%= cos.avatar_deco ? cos.avatar_deco.css : '' %>"
        data-preview="avatar_deco" aria-hidden="true" <%= cos.avatar_deco ? '' : 'hidden' %>><%= cos.avatar_deco ? cos.avatar_deco.glyph : '' %></span>
    </span>
    <div class="profile-id">
      <h1><%= user.display_name %></h1>
      <p class="text-muted">@<%= user.username %></p>
      <div class="profile-tagline">
        <span class="cos-title" data-preview="title" <%= title0 ? '' : 'hidden' %>
          style="--rarity-color: <%= title0 ? cosmeticRarities[title0.rarity].color : 'transparent' %>">
          <span data-preview-text><%= title0 ? title0.text : '' %></span>
        </span>
      </div>
    </div>
    <div class="profile-meta">
      <div class="profile-level">
        <span class="chip">Nivel <%= level.level %></span>
        <span class="profile-xp text-muted"><%= level.xp %> XP</span>
      </div>
    </div>
    <% if (user.bio) { %><p class="profile-bio"><%= user.bio %></p><% } %>
  </section>

  <p class="col-count text-muted">
    <% if (collection.ownedCount === 0) { %>
      Aún no tienes objetos. Los conseguirás en la tienda, el pase y las cajas.
    <% } else { %>
      <%= collection.ownedCount %> <%= collection.ownedCount === 1 ? 'objeto conseguido' : 'objetos conseguidos' %>
    <% } %>
  </p>

  <% collection.slots.forEach((slot) => { %>
  <section class="card col-slot" data-slot="<%= slot.key %>">
    <h2><%= slot.label %></h2>
    <p class="text-muted col-slot-desc"><%= slot.desc %></p>

    <div class="col-grid">
      <% slot.items.forEach((item) => { %>
      <%
        const rarity = cosmeticRarities[item.rarity];
        const isEquipped = slot.equippedKey === item.key;
      %>
      <button type="button"
        class="col-item <%= item.owned ? 'is-owned' : 'is-locked' %> <%= isEquipped ? 'is-equipped' : '' %>"
        style="--rarity-color: <%= rarity.color %>"
        data-slot="<%= slot.key %>"
        data-rarity="<%= item.rarity %>"
        data-key="<%= item.key %>"
        data-css="<%= item.css || '' %>"
        data-glyph="<%= item.glyph || '' %>"
        data-text="<%= item.text || '' %>"
        data-color="<%= rarity.color %>"
        data-bare="<%= item.replaceBorder ? '1' : '' %>"
        data-gap="<%= item.gap ? '1' : '' %>"
        data-inner="<%= item.innerBorder ? '1' : '' %>"
        data-ink="<%= item.ink || '' %>"
        <%= item.owned ? '' : 'disabled' %>
        aria-pressed="<%= isEquipped %>"
        title="<%= item.owned ? `${item.name} · ${rarity.label}` : `${item.name} · ${rarity.label} (aún no lo tienes)` %>">

        <span class="col-item-art">
          <% if (slot.key === 'avatar_frame') { %>
          <span class="avatar-wrap avatar-wrap-sm <%= cosmeticFrameClasses(item) %>">
            <span class="avatar avatar-sm avatar-initials col-item-face"></span>
            <span class="cos-frame <%= item.css %>" aria-hidden="true"></span>
          </span>
          <% } else if (slot.key === 'avatar_deco') { %>
          <span class="col-item-glyph"><%= item.glyph %></span>
          <% } else if (slot.key === 'title') { %>
          <span class="cos-title" style="--rarity-color: <%= rarity.color %>"><span><%= item.text %></span></span>
          <% } else { %>
          <span class="col-swatch cos-card <%= item.replaceBorder ? 'cos-card-bare' : '' %> <%= item.gap ? 'cos-cframe-gap' : '' %> <%= item.css %>" aria-hidden="true"></span>
          <% } %>
        </span>

        <span class="col-item-name"><%= item.name %></span>
        <% if (!item.owned) { %><span class="col-item-lock">🔒</span><% } %>
        <% if (isEquipped) { %><span class="col-item-check">✓</span><% } %>
      </button>
      <% }) %>
    </div>
  </section>
  <% }) %>

  <p class="col-hint text-muted">
    Los objetos que aún no tienes se conseguirán en la tienda. Todavía no está
    abierta 🌱
  </p>
</main>

<%- include('../partials/foot', { scripts: ['/js/collection.js'] }) %>
