<%- include('../partials/head', { title, styles: ['/css/pages/auth.css'] }) %>

<main class="auth-page">
  <div class="auth-card card card-glass">
    <a class="brand auth-brand" href="/">
      <span class="brand-mark">★</span><span class="brand-name"><%= appName %></span>
    </a>
    <h1>Hola de nuevo</h1>
    <p class="text-muted auth-sub">Nos alegra que vuelvas 👋</p>

    <%- include('../partials/flash') %>

    <% if (error) { %>
    <div class="form-error"><%= error %></div>
    <% } %>

    <form method="post" action="/login" class="form" novalidate>
      <%- include('../partials/csrf-field') %>

      <%- include('../partials/field', { field: {
        name: 'username', label: 'Usuario', value: values.username,
        error: errors.username, required: true, autocomplete: 'username'
      } }) %>

      <%- include('../partials/field', { field: {
        name: 'password', label: 'Contraseña', type: 'password',
        error: errors.password, required: true, autocomplete: 'current-password'
      } }) %>

      <button class="btn btn-primary btn-block" type="submit">Entrar</button>
    </form>

    <p class="auth-alt">¿No tienes cuenta? <a class="link" href="/register">Crea una</a></p>
  </div>
</main>

<%- include('../partials/foot') %>
