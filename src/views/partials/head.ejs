<!doctype html>
<html lang="es" data-theme="<%= typeof theme !== 'undefined' ? theme : 'dark' %>" data-accent="<%= typeof accent !== 'undefined' ? accent : 'blue' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="<%= (typeof theme !== 'undefined' && theme === 'light') ? '#f0eee6' : '#0f1420' %>" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><text x='12' y='12' font-size='24' text-anchor='middle' dominant-baseline='central' transform='rotate(-10 12 12)' fill='%234f8cff'>★</text></svg>" />
    <!-- PWA: manifest + icono para "Añadir a pantalla de inicio" (necesario para push en iOS). -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="<%= asset('/icons/apple-touch-icon.png') %>" />
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <% } %>
    <% if (typeof vapidPublicKey !== 'undefined' && vapidPublicKey) { %>
    <meta name="vapid-public-key" content="<%= vapidPublicKey %>" />
    <% } %>
    <title><%= typeof title !== 'undefined' ? title : appName %></title>

    <%
      // Previews sociales (Open Graph / Twitter Card). Por defecto muestran la
      // marca; una página puede sobreescribir con `ogTitle` / `ogDescription`.
      const _ogTitle = typeof ogTitle !== 'undefined' ? ogTitle : appName;
      const _ogDesc = typeof ogDescription !== 'undefined' ? ogDescription
        : (typeof siteDescription !== 'undefined' ? siteDescription : '');
      const _ogBase = typeof baseUrl !== 'undefined' ? baseUrl : '';
      const _ogImage = _ogBase + '/og-image.png';
    %>
    <meta name="description" content="<%= _ogDesc %>" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="<%= appName %>" />
    <meta property="og:title" content="<%= _ogTitle %>" />
    <meta property="og:description" content="<%= _ogDesc %>" />
    <% if (typeof canonicalUrl !== 'undefined') { %>
    <meta property="og:url" content="<%= canonicalUrl %>" />
    <% } %>
    <meta property="og:image" content="<%= _ogImage %>" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="<%= appName %>" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= _ogTitle %>" />
    <meta name="twitter:description" content="<%= _ogDesc %>" />
    <meta name="twitter:image" content="<%= _ogImage %>" />

    <%
      // Los estáticos salen con `?v=<hash>` (app.locals.asset) para que el móvil
      // no se quede con una versión vieja en caché. Ver src/utils/assets.js.
      const _globalStyles = [
        '/css/tokens.css',
        '/css/reset.css',
        '/css/base.css',
        '/css/components/forms.css',
        '/css/components/avatar.css',
        '/css/components/nav.css',
        '/css/components/bottom-nav.css',
        '/css/components/toast.css',
        '/css/components/feed.css',
        '/css/components/user-row.css',
      ];
    %>
    <% _globalStyles.concat(typeof styles !== 'undefined' ? styles : []).forEach((href) => { %>
    <link rel="stylesheet" href="<%= asset(href) %>" />
    <% }) %>
  </head>
  <body>
