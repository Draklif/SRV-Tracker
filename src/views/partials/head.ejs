<!doctype html>
<html lang="es" data-theme="<%= typeof theme !== 'undefined' ? theme : 'dark' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="<%= (typeof theme !== 'undefined' && theme === 'light') ? '#f0eee6' : '#0f1420' %>" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><text x='2' y='19' font-size='19' transform='rotate(-10 12 12)' fill='%234f8cff'>★</text></svg>" />
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <% } %>
    <title><%= typeof title !== 'undefined' ? title : appName %></title>

    <%
      // Previews sociales (Open Graph / Twitter Card). Por defecto muestran la
      // marca; una página puede sobreescribir con `ogTitle` / `ogDescription`.
      const _ogTitle = typeof ogTitle !== 'undefined' ? ogTitle : appName;
      const _ogDesc = typeof ogDescription !== 'undefined' ? ogDescription
        : (typeof siteDescription !== 'undefined' ? siteDescription : '');
      const _ogBase = typeof baseUrl !== 'undefined' ? baseUrl : '';
      const _ogImage = _ogBase + '/og-image.png';
    %>
    <meta name="description" content="<%= _ogDesc %>" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="<%= appName %>" />
    <meta property="og:title" content="<%= _ogTitle %>" />
    <meta property="og:description" content="<%= _ogDesc %>" />
    <% if (typeof canonicalUrl !== 'undefined') { %>
    <meta property="og:url" content="<%= canonicalUrl %>" />
    <% } %>
    <meta property="og:image" content="<%= _ogImage %>" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="<%= appName %>" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= _ogTitle %>" />
    <meta name="twitter:description" content="<%= _ogDesc %>" />
    <meta name="twitter:image" content="<%= _ogImage %>" />

    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/reset.css" />
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/components/forms.css" />
    <link rel="stylesheet" href="/css/components/avatar.css" />
    <link rel="stylesheet" href="/css/components/nav.css" />
    <link rel="stylesheet" href="/css/components/bottom-nav.css" />
    <link rel="stylesheet" href="/css/components/toast.css" />
    <link rel="stylesheet" href="/css/components/feed.css" />
    <link rel="stylesheet" href="/css/components/user-row.css" />
    <% (typeof styles !== 'undefined' ? styles : []).forEach((href) => { %>
    <link rel="stylesheet" href="<%= href %>" />
    <% }) %>
  </head>
  <body>
