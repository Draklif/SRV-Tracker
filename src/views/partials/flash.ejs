<% if (flash && flash.length) { %>
<%# Datos, no código: la CSP (script-src 'self') no ejecuta esto. toast.js lo
    lee y muestra cada mensaje como un toast efímero. Escapamos '<' para no
    romper la etiqueta ni permitir inyección. %>
<script type="application/json" id="flash-data"><%- JSON.stringify(flash).replace(/</g, '\\u003c') %></script>
<% } %>
