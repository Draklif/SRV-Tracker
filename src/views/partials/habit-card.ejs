<%
  // Flag propio (cardArchived): el local `archived` de la página /habits es un
  // ARRAY y se filtra al include por el scope de EJS ([] es truthy → bug).
  const isArchived = typeof cardArchived !== 'undefined' ? Boolean(cardArchived) : false;
  const colorHex = habitColors[habit.color] || habitColors.blue;
  const meta = habitTypeMeta[habit.type];
  // Config serializada para prellenar el modal de edición sin otra petición.
  const cfg = {
    id: habit.id, name: habit.name, icon: habit.icon, color: habit.color,
    type: habit.type, resourceType: habit.resource_type,
    unit: habit.unit, targetDaily: habit.target_daily, settings: habit.settings,
  };
%>
<article class="habit-card<%= isArchived ? ' is-archived' : '' %>"
  data-habit-id="<%= habit.id %>" data-json="<%= JSON.stringify(cfg) %>"
  style="--habit-color: <%= colorHex %>">
  <span class="habit-icon"><%= habit.icon %></span>

  <div class="habit-main">
    <h3 class="habit-name"><%= habit.name %></h3>
    <p class="habit-meta">
      <span class="habit-type"><%= meta ? meta.label : habit.type %></span>
      <% if (habit.target_daily) { %>
      <span class="dot">·</span><span>Meta <%= habit.target_daily %><%= habit.unit ? ' ' + habit.unit : '' %></span>
      <% } else if (habit.unit) { %>
      <span class="dot">·</span><span><%= habit.unit %></span>
      <% } %>
    </p>
  </div>

  <% if (!isArchived) { %>
  <button class="hc-expand" data-action="card-toggle" aria-expanded="false" aria-label="Más opciones">
    <%- include('icon', { name: 'down', size: 16 }) %>
  </button>
  <% } %>

  <div class="habit-actions">
    <% if (isArchived) { %>
    <button class="icon-btn" data-action="restore" title="Restaurar" aria-label="Restaurar hábito">
      <%- include('icon', { name: 'restore', size: 17 }) %>
    </button>
    <% } else { %>
    <button class="icon-btn move" data-action="up" title="Subir" aria-label="Subir">
      <%- include('icon', { name: 'up', size: 16 }) %>
    </button>
    <button class="icon-btn move" data-action="down" title="Bajar" aria-label="Bajar">
      <%- include('icon', { name: 'down', size: 16 }) %>
    </button>
    <a class="icon-btn" href="/habits/<%= habit.id %>/history" title="Historial" aria-label="Ver historial">
      <%- include('icon', { name: 'chart', size: 17 }) %>
    </a>
    <button class="icon-btn" data-action="edit" title="Editar" aria-label="Editar hábito">
      <%- include('icon', { name: 'pencil', size: 17 }) %>
    </button>
    <button class="icon-btn" data-action="archive" title="Archivar" aria-label="Archivar hábito">
      <%- include('icon', { name: 'archive', size: 17 }) %>
    </button>
    <% } %>
  </div>
</article>
