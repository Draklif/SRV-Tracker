<%
  /**
   * Arte de una CAJA (lootbox): SVG inline, uno de un POOL de 5 diseños. La caja
   * elige cuál con su campo `art` en src/config/lootboxes.js; aquí solo se pintan.
   *
   * El trazo hereda color con currentColor (se adapta al tema claro/oscuro); los
   * rellenos dan identidad a cada caja. Los emojis quedan para hábitos, logros y
   * reacciones, igual que en partials/icon.ejs.
   *
   * Uso: include('box-art', { art: box.art, size: 52 })
   *
   * Añadir un diseño al pool = una entrada más aquí (y ya se puede referenciar
   * desde `art` en la config de cajas).
   */
  const BOX_ART = {
    // Cartón: caja de reparto con cinta en cruz. La más humilde del pool.
    carton:
      '<rect x="12" y="30" width="40" height="24" rx="2" fill="#cf9b5f" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<rect x="9" y="18" width="46" height="12" rx="2" fill="#e0b277" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<path d="M32 18V54" stroke="currentColor" stroke-width="2.5"/>' +
      '<path d="M26 24h12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>',
    // Madera: cajón de tablones con vetas y juntas.
    madera:
      '<rect x="12" y="30" width="40" height="24" rx="2" fill="#b07a44" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<rect x="9" y="18" width="46" height="12" rx="2" fill="#c68a4e" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<path d="M12 38h40M12 46h40" stroke="currentColor" stroke-width="2" opacity="0.55"/>' +
      '<path d="M22 30v24M42 30v24" stroke="currentColor" stroke-width="2" opacity="0.55"/>',
    // Hierro: caja remachada con cerradura central. Sólida.
    hierro:
      '<rect x="12" y="30" width="40" height="24" rx="2" fill="#8a99a8" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<rect x="9" y="18" width="46" height="12" rx="2" fill="#6f7d8c" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<circle cx="17" cy="35" r="2" fill="currentColor"/><circle cx="47" cy="35" r="2" fill="currentColor"/>' +
      '<circle cx="17" cy="49" r="2" fill="currentColor"/><circle cx="47" cy="49" r="2" fill="currentColor"/>' +
      '<rect x="27" y="23" width="10" height="11" rx="1.5" fill="#cfd8e0" stroke="currentColor" stroke-width="2.5"/>',
    // Dorada: cofre de oro con broche de diamante.
    dorada:
      '<rect x="12" y="30" width="40" height="24" rx="2" fill="#e8b84b" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<rect x="9" y="18" width="46" height="12" rx="2" fill="#d29e2f" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<path d="M12 42h40" stroke="currentColor" stroke-width="2" opacity="0.5"/>' +
      '<path d="M32 20l6 6-6 6-6-6z" fill="#fff3c4" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>',
    // Prisma: caja arcana con un cristal flotando encima.
    prisma:
      '<rect x="12" y="30" width="40" height="24" rx="2" fill="#7c6bd6" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<rect x="9" y="18" width="46" height="12" rx="2" fill="#5f4fb0" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>' +
      '<path d="M32 5l7 8-7 8-7-8z" fill="#b8a6ff" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>' +
      '<path d="M25 13h14M32 5v16" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>',
  };
  const s = typeof size !== 'undefined' ? size : 48;
  const key = typeof art !== 'undefined' && BOX_ART[art] ? art : 'carton';
%>
<svg class="box-art box-art-<%= key %>" width="<%= s %>" height="<%= s %>" viewBox="0 0 64 64"
  fill="none" aria-hidden="true"><%- BOX_ART[key] %></svg>
