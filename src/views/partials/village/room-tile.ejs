<%
  // Una sala del mapa, posicionada por su huella (floor, col, width). El cliente
  // (village.js) calcula el layout absoluto y el paneo; aquí solo el marcado +
  // los data-* que necesita. Params: room (fila de village_rooms), roomMeta.
  const meta = roomMeta[room.room_type] || {};
  const isNucleo = room.room_type === 'nucleo';
  const inObras = room.status !== 'built'; // 'constructing' o 'moving'
%>
<button type="button"
        class="room-tile<%= isNucleo ? ' is-nucleo' : ' is-built' %><%= inObras ? ' is-building' : '' %>"
        data-action="<%= isNucleo ? 'nucleo' : 'room' %>"
        data-room-id="<%= room.id %>"
        data-room-type="<%= room.room_type %>"
        data-floor="<%= room.floor %>"
        data-col="<%= room.col %>"
        data-width="<%= room.width %>"
        data-level="<%= room.level %>"
        data-status="<%= room.status %>"
        data-finish="<%= room.construct_finish_at || '' %>">
  <span class="room-icon" aria-hidden="true"><%= meta.icon %></span>
  <span class="room-name"><%= meta.label %></span>
  <% if (!isNucleo) { %><span class="room-lvl">Nv <%= room.level %></span><% } %>
  <% if (inObras) { %>
  <span class="room-status" data-countdown="<%= room.construct_finish_at %>"><%= room.status === 'moving' ? 'Moviendo…' : 'En obras…' %></span>
  <% } %>
</button>
