    <%
      // Scripts globales (en todas las páginas), en orden de dependencia:
      // motion.js (window.motion: barra de carga y skeletons; el primero, porque
      // otras páginas lo usan), toast.js (flashes), api.js (window.api para
      // fetch+CSRF), push.js (SW + opt-in), coins.js (el saldo del nav, que
      // cualquier página puede mover).
      // Salen con `?v=<hash>` (app.locals.asset) para el cache busting en móvil.
      const _globalScripts = [
        '/js/motion.js',
        '/js/toast.js',
        '/js/api.js',
        '/js/push.js',
        '/js/cosmetics.js',
        '/js/coins.js',
      ];
      // Evitar duplicar los globales si una página los lista en su array `scripts`.
      const _pageScripts = (typeof scripts !== 'undefined' ? scripts : [])
        .filter((src) => !_globalScripts.includes(src));
    %>
    <% _globalScripts.concat(_pageScripts).forEach((src) => { %>
    <script src="<%= asset(src) %>" defer></script>
    <% }) %>
  </body>
</html>
