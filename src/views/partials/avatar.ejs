<%
  const au = typeof avatarUser !== 'undefined' ? avatarUser : user;
  const sz = typeof size !== 'undefined' ? size : 'md';
  const label = au.display_name || au.username || '?';
  const initial = label.trim().charAt(0).toUpperCase();
  const palette = ['#4f8cff', '#2b5fd9', '#39c6d6', '#e8945a', '#8f7bf2', '#d97ba8'];
  const seed = (au.username || label).split('').reduce((a, c) => a + c.charCodeAt(0), 0);
  const bg = palette[seed % palette.length];
%>
<% if (au.avatar_path) { %>
<img class="avatar avatar-<%= sz %>" src="<%= au.avatar_path %>" alt="Avatar de <%= label %>" />
<% } else { %>
<span class="avatar avatar-<%= sz %> avatar-initials" style="background: <%= bg %>"><%= initial %></span>
<% } %>
